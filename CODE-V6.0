// Derive Action Zone from Score
string macro_action = "CASH / HEDGE"
color macro_action_col = color.red

if macro_score >= 80
    macro_action := "AGGRESSIVE"
    macro_action_col := #0F6E56
else if macro_score >= 60
    macro_action := "FULL SIZE"
    macro_action_col := #1D9B52
else if macro_score >= 40
    macro_action := "HALF SIZE"
    macro_action_col := #854F0B
else if macro_score >= 20
    macro_action := "TRAPS ONLY"
    macro_action_col := #A32D2D

