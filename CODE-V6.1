if finalBullSOS and isValidTF 
    string sigs = getSignalString()
    string zoneTag = " [Z" + str.tostring(macro_action_code) + "]"
    alert("**BULL SOS [" + sigs + "]" + zoneTag + "** on " + syminfo.tickerid + " [" + fixedTF + "] | Macro: " + macro_action_text, alert.freq_once_per_bar)

// ══════════════════════════════════════════════════════════════════════════════
// DASHBOARD (Updated — replaced MMFI/Breadth/Index rows with Macro Zone)
// ══════════════════════════════════════════════════════════════════════════════

statsTablePos = switch statsTablePosition
    "Top Left"      => position.top_left
    "Top Right"     => position.top_right
    "Top Center"    => position.top_center
    "Bottom Center" => position.bottom_center
    "Bottom Right"  => position.bottom_right
    "Bottom Left"   => position.bottom_left
    "Center"        => position.middle_center
    "Center Right"  => position.middle_right
    "Center Left"   => position.middle_left

statsTableSize = switch statsTableTextSize
    "Tiny" => size.tiny
    "Small" => size.small
    "Normal" => size.normal
    "Large" => size.large

string maHeader = "MA Ext " + str.tostring(maExtLength)
string brkHeader = str.tostring(calcBreakoutPct * 100, "#.#") + "% B/O ATR"

var string[] headers = na
if enableRegime
    headers := array.new_string()
    array.push(headers, 'TF')
    array.push(headers, 'Bull SOS')
    if show_d_macro
        array.push(headers, 'Macro Score')
    if show_d_action
        array.push(headers, 'S.A. Action')
    if show_d_spy
        array.push(headers, 'SPY Trend')
    if show_d_chop
        array.push(headers, 'Chop')
    array.push(headers, 'Corr (5D)')
    array.push(headers, 'HTF')
    array.push(headers, 'Chart')
    array.push(headers, maHeader)
    array.push(headers, brkHeader)
    if show_d_avgbars and enableRegime
        array.push(headers, 'Avg Bars')

var table statsTable = na
if barstate.isfirst and showStatsTable
    int cols = statsTableOrientation == "Vertical" ? 2 : array.size(headers)
    int rows = statsTableOrientation == "Vertical" ? array.size(headers) : 2
    statsTable := table.new(statsTablePos, cols, rows, bgcolor=dashBgColor)

f_populateStatsDashboard() =>
    if na(statsTable) or not showStatsTable
        na
    else     
        string tfDisplay = fixedTF == "240" ? "4H" : fixedTF == "D" ? "Daily" : fixedTF
        string val_bull = finalBullSOS ? "Yes" : "No"
        
        // ── NEW: Macro Score with delta ──
        float macro_delta = macro_composite - nz(macro_composite[1])
        string val_macro = str.tostring(macro_composite, "#.1") + (macro_delta >= 0 ? " (+" : " (") + str.tostring(macro_delta, "#.1") + ")"
        
        string val_action = macro_action_text
        string val_spy = spy_trend
        string val_chop = chop_state + " (" + str.tostring(idxChopVal, "#.1") + ")"
        string val_corr = str.tostring(corr_val, "#.##")
        string val_htf = htfText
        string val_context = vcpReady ? "VCP: READY" : trendContext
        string val_ext = str.tostring(extATR, "#.##") + " atr (" + str.tostring(extPct, "#.##") + "%)"
        
        string[] values = array.new_string()
        color[] cellColors = array.new_color()
        
        // TF
        array.push(values, tfDisplay)
        array.push(cellColors, color.gray)
        
        // Bull SOS
        array.push(values, val_bull)
        array.push(cellColors, finalBullSOS ? color.new(color.green, 40) : color.new(color.red, 40))
        
        // Macro Score (conditional)
        if show_d_macro
            array.push(values, val_macro)
            array.push(cellColors, macro_composite >= 60 ? color.new(#1D9B52, 40) : macro_composite >= 40 ? color.new(#854F0B, 40) : color.new(#A32D2D, 40))
        
        // S.A. Action (conditional)
        if show_d_action
            array.push(values, val_action)
            array.push(cellColors, color.new(macro_action_col, 20))
        
        // SPY Trend (conditional)
        if show_d_spy
            array.push(values, val_spy)
            color spy_bg = spy_trend == "POWER TREND" ? color.new(#0F6E56, 0) : spy_trend == "UPTREND" ? color.new(#1D9B52, 0) : spy_trend == "PULLBACK" ? color.new(#185FA5, 0) : spy_trend == "DEEP PULLBACK" ? color.new(#854F0B, 0) : color.new(#A32D2D, 0)
            array.push(cellColors, spy_bg)
        
        // Chop (conditional)
        if show_d_chop
            array.push(values, val_chop)
            array.push(cellColors, idxChopVal > chopThreshChaos ? color.new(color.red, 40) : idxChopVal > chopThreshTrans ? color.new(color.orange, 40) : color.new(color.green, 40))
        
        // Corr (always)
        array.push(values, val_corr)
        array.push(cellColors, corr_ok ? color.new(color.green, 40) : color.new(color.orange, 0))
        
        // HTF (always)
        array.push(values, val_htf)
        array.push(cellColors, htfBullish ? color.new(color.green, 0) : color.new(color.red, 0))
        
        // Chart (always)
        array.push(values, val_context)
        color chart_bg = dashValueColor
        if vcpReady
            chart_bg := color.new(color.blue, 0)
        else
            chart_bg := switch trendContext
                "POWER TREND" => color.new(#4caf50, 0)
                "PULLBACK" => color.new(color.blue, 0)
                "DEEP PULLBACK" => color.new(color.orange, 0)
                "BEAR / REPAIR" => color.new(color.red, 0)
                => dashValueColor
        array.push(cellColors, chart_bg)
        
        // MA Ext (always)
        array.push(values, val_ext)
        array.push(cellColors, extATR > maExtThresh ? color.new(color.red, 0) : color.new(color.green, 40))
        
        // BRK (always)
        string val_brk = str.tostring(calcAutoMult, "#.##") + "×"
        array.push(values, val_brk)
        array.push(cellColors, calcAutoMult >= 2.0 ? color.new(color.red, 0) : calcAutoMult >= 1.0 ? color.new(color.green, 40) : color.new(color.yellow, 0))
        
        // Avg Bars (conditional)
        if show_d_avgbars and enableRegime
            array.push(values, str.tostring(avgBars, "#.#"))
            array.push(cellColors, color.gray)

        for i = 0 to array.size(headers) - 1
            int c = statsTableOrientation == "Vertical" ? 0 : i
            int r = statsTableOrientation == "Vertical" ? i : 0
            
            table.cell(statsTable, c, r, array.get(headers, i), text_color=color.white, bgcolor=dashHeaderColor, text_halign=text.align_center, text_size=statsTableSize)

            color cellBg = i < array.size(cellColors) ? array.get(cellColors, i) : dashValueColor

            int vCol = statsTableOrientation == "Vertical" ? 1 : c
            int vRow = statsTableOrientation == "Vertical" ? r : 1
            table.cell(statsTable, vCol, vRow, array.get(values, i), text_color=color.white, bgcolor=cellBg, text_halign=text.align_center, text_size=statsTableSize)


f_populateStatsDashboard()

// ══════════════════════════════════════════════════════════════════════════════
// BACKTEST ENGINE (Section 0 Logic)
// ══════════════════════════════════════════════════════════════════════════════
bool bt_validTF_raw = timeframe.isdaily or timeframe.period == "240" or timeframe.isweekly
bool bt_validTF = bt_enabled and bt_validTF_raw
bool bt_inDateRange = bt_allDates or (time >= bt_dateFrom and time <= bt_dateTo)

// --- Signal Selection ---
f_bt_getSignal() =>
    switch bt_signal
        "All"          => finalBullSOS
        "SD"           => finalBullSOS and standardSOS
        "DR"           => finalBullSOS and drBull
        "CT"           => finalBullSOS and ctBull
        "VCP"          => finalBullSOS and vcpBull
        "H2"           => finalBullSOS and high2Bull
        "CDL"          => finalBullSOS and candleBull
        "Multi-Signal" => finalBullSOS and sigCount >= 2

bool bt_rawSignal = f_bt_getSignal()

// --- Macro Zone Filter ---
bool bt_macroPass = true
if bt_useMacroFilter
    bt_macroPass := (bt_mz5 and macro_action_code == 4) or (bt_mz4 and macro_action_code == 3) or (bt_mz3 and macro_action_code == 2) or (bt_mz2 and macro_action_code == 1) or (bt_mz1 and macro_action_code == 0)

// --- Trend Context Filter ---
bool bt_trendPass = true
if bt_useTrendFilter
    bt_trendPass := (bt_tf_power and trendContext == "POWER TREND") or (bt_tf_pull and trendContext == "PULLBACK") or (bt_tf_deep and trendContext == "DEEP PULLBACK") or (bt_tf_bear and trendContext == "BEAR / REPAIR")

bool bt_signal_final = bt_rawSignal and bt_macroPass and bt_trendPass and bt_validTF and bt_inDateRange

// --- Validate day range ---
int bt_dStart = math.min(bt_dayStart, bt_dayEnd)
int bt_dEnd   = math.max(bt_dayStart, bt_dayEnd)
int bt_numDays = bt_dEnd - bt_dStart + 1

// --- Tracking Arrays ---
var array<float> bt_avgGain    = array.new_float()
var array<float> bt_avgLoss    = array.new_float()
var array<int>   bt_wins       = array.new_int()
var array<int>   bt_losses     = array.new_int()
var array<float> bt_totalGain  = array.new_float()
var array<float> bt_totalLoss  = array.new_float()
var array<float> bt_rr         = array.new_float()

// LOD tracking
var array<float> bt_lodBarsSum = array.new_float()
var array<int>   bt_lodCount   = array.new_int()

// Signal state
var float bt_entryPrice = na
var float bt_entryLOD   = na
var float bt_entryATR   = na
var int   bt_barCount   = 0
var bool  bt_isOn       = false
var int   bt_sigCount   = 0
var bool  bt_lodTouched = false

// Initialize arrays on first bar
if barstate.isfirst
    for _i = 0 to bt_numDays - 1
        array.push(bt_avgGain, 0.0)
        array.push(bt_avgLoss, 0.0)
        array.push(bt_wins, 0)
        array.push(bt_losses, 0)
        array.push(bt_totalGain, 0.0)
        array.push(bt_totalLoss, 0.0)
        array.push(bt_rr, 0.0)
    array.push(bt_lodBarsSum, 0.0)
    array.push(bt_lodCount, 0)

// --- Entry ---
if bt_signal_final and not bt_isOn
    bt_entryPrice := close
    bt_entryLOD   := low
    bt_entryATR   := ta.atr(bt_atrLen)
    bt_barCount   := 0
    bt_isOn       := true
    bt_sigCount   += 1
    bt_lodTouched := false

// --- Track ---
if bt_isOn
    bt_barCount += 1

    // LOD touch tracking (bars until signal day's LOD is violated)
    if not bt_lodTouched and low <= bt_entryLOD
        bt_lodTouched := true
        float lodBarsOld = array.get(bt_lodBarsSum, 0)
        array.set(bt_lodBarsSum, 0, lodBarsOld + bt_barCount)
        int lodCntOld = array.get(bt_lodCount, 0)
        array.set(bt_lodCount, 0, lodCntOld + 1)

    // Check each test day
    if bt_barCount >= bt_dStart and bt_barCount <= bt_dEnd
        int idx = bt_barCount - bt_dStart
        if idx >= 0 and idx < array.size(bt_avgGain)
            float pctChange = (close / bt_entryPrice - 1) * 100

            if pctChange > 0
                // Winner: add to wins, accumulate gain
                array.set(bt_wins, idx, array.get(bt_wins, idx) + 1)
                array.set(bt_totalGain, idx, array.get(bt_totalGain, idx) + pctChange)
            else
                // Loser: add to losses, accumulate loss
                array.set(bt_losses, idx, array.get(bt_losses, idx) + 1)
                array.set(bt_totalLoss, idx, array.get(bt_totalLoss, idx) + pctChange)

            // Recalculate averages
            int w = array.get(bt_wins, idx)
            int l = array.get(bt_losses, idx)

            // Avg Gain = sum of winning trades / number of winners
            float avgG = w > 0 ? array.get(bt_totalGain, idx) / w : 0.0
            // Avg Loss = sum of losing trades / number of losers
            float avgL = l > 0 ? array.get(bt_totalLoss, idx) / l : 0.0

            array.set(bt_avgGain, idx, avgG)
            array.set(bt_avgLoss, idx, avgL)

            // RR = avg win / |avg loss| (simple V7 style)
            float rrVal = math.abs(avgL) > 0.01 ? avgG / math.abs(avgL) : 0.0
            array.set(bt_rr, idx, rrVal)

    // Exit after last test day
    if bt_barCount >= bt_dEnd
        bt_isOn := false

// --- Backtest Table ---
bt_tblPos = switch bt_tablePos
    "Top Left"      => position.top_left
    "Top Right"     => position.top_right
    "Top Center"    => position.top_center
    "Bottom Left"   => position.bottom_left
    "Bottom Right"  => position.bottom_right
    "Bottom Center" => position.bottom_center

bt_tblSize = switch bt_tableSize
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large

// Dynamic stop label
string bt_stopLabel = bt_stopMethod == "LOD" ? "Avg Loss (LOD)" : "Avg Loss (" + str.tostring(bt_atrMult, "#.#") + " ATR)"

// Build header row label
string bt_sigLabel = bt_signal + (bt_useMacroFilter ? " | MZ" : "") + (bt_useTrendFilter ? " | TF" : "")

// Avg Bars to LOD
float bt_avgBarsToLOD = array.size(bt_lodCount) > 0 and array.get(bt_lodCount, 0) > 0 ? array.get(bt_lodBarsSum, 0) / array.get(bt_lodCount, 0) : na

// Row labels
var string[] bt_rowLabels = array.from("Avg Gain %", "", "Win %", "RR", "Total Gain %", "Avg Bars→LOD", "Signals")

var table bt_table = na

// TF message removed — backtest table only visible on valid TFs

if barstate.isfirst and bt_showTable and bt_validTF
    int bt_cols = bt_tableOrient == "Horizontal" ? bt_numDays + 1 : 8  // +1 for label col  |  7 rows + 1 header
    int bt_rows = bt_tableOrient == "Horizontal" ? 8 : bt_numDays + 1
    bt_table := table.new(bt_tblPos, bt_cols, bt_rows, bgcolor=bt_bgColor, border_width=1, frame_color=color.gray)

f_populateBacktestTable() =>
    if na(bt_table) or not bt_showTable or not bt_validTF or not bt_enabled
        na
    else
        // Update the stop label in row labels array dynamically
        array.set(bt_rowLabels, 1, bt_stopLabel)

        if bt_tableOrient == "Horizontal"
            // Row 0 headers: label column + day columns
            table.cell(bt_table, 0, 0, bt_sigLabel, text_color=color.black, bgcolor=bt_lblColor, text_halign=text.align_center, text_size=bt_tblSize)
            for d = 0 to bt_numDays - 1
                int dayNum = bt_dStart + d
                table.cell(bt_table, d + 1, 0, "Day " + str.tostring(dayNum), text_color=color.black, bgcolor=bt_lblColor, text_halign=text.align_center, text_size=bt_tblSize)

            // Row labels in column 0
            for r = 0 to array.size(bt_rowLabels) - 1
                table.cell(bt_table, 0, r + 1, array.get(bt_rowLabels, r), text_color=color.white, bgcolor=bt_hdrColor, text_halign=text.align_center, text_size=bt_tblSize)

            // Data cells
            for d = 0 to bt_numDays - 1
                if d < array.size(bt_avgGain)
                    float ag  = array.get(bt_avgGain, d)
                    float al  = array.get(bt_avgLoss, d)
                    int   w   = array.get(bt_wins, d)
                    int   l   = array.get(bt_losses, d)
                    int   tot = w + l
                    float wp  = tot > 0 ? (w / tot) * 100 : 0
                    float rr  = array.get(bt_rr, d)
                    float tg  = array.get(bt_totalGain, d) + array.get(bt_totalLoss, d)

                    color gainCol = ag >= 0 ? color.new(color.green, 60) : color.new(color.red, 60)
                    color lossCol = color.new(color.red, 60)
                    color winCol  = wp >= 50 ? color.new(color.green, 60) : color.new(color.red, 60)
                    color rrCol   = rr >= 1 ? color.new(color.green, 60) : color.new(color.orange, 60)

                    // Row 1: Avg Gain (winners only)
                    table.cell(bt_table, d + 1, 1, str.tostring(ag, "#.##") + "%", text_color=color.white, bgcolor=gainCol, text_halign=text.align_center, text_size=bt_tblSize)
                    // Row 2: Avg Loss (losers only)
                    table.cell(bt_table, d + 1, 2, str.tostring(al, "#.##") + "%", text_color=color.white, bgcolor=lossCol, text_halign=text.align_center, text_size=bt_tblSize)
                    // Row 3: Win %
                    table.cell(bt_table, d + 1, 3, str.tostring(wp, "#.##") + "%", text_color=color.white, bgcolor=winCol, text_halign=text.align_center, text_size=bt_tblSize)
                    // Row 4: RR
                    table.cell(bt_table, d + 1, 4, str.tostring(rr, "#.##"), text_color=color.white, bgcolor=rrCol, text_halign=text.align_center, text_size=bt_tblSize)
                    // Row 5: Total Gain (net of all trades)
                    table.cell(bt_table, d + 1, 5, str.tostring(tg, "#.##") + "%", text_color=color.white, bgcolor=tg >= 0 ? color.new(color.green, 60) : color.new(color.red, 60), text_halign=text.align_center, text_size=bt_tblSize)
                    // Rows 6 & 7: Merge into single cells (first column only)
                    if d == 0
                        string lodStr = not na(bt_avgBarsToLOD) ? str.tostring(bt_avgBarsToLOD, "#.1") + " bars" : "N/A"
                        table.cell(bt_table, 1, 6, lodStr, text_color=color.white, bgcolor=bt_valColor, text_halign=text.align_center, text_size=bt_tblSize)
                        table.cell(bt_table, 1, 7, str.tostring(tot) + " signals", text_color=color.white, bgcolor=bt_valColor, text_halign=text.align_center, text_size=bt_tblSize)
                        if bt_numDays > 1
                            table.merge_cells(bt_table, 1, 6, bt_numDays, 6)
                            table.merge_cells(bt_table, 1, 7, bt_numDays, 7)

            // Signal count label already in bt_rowLabels

        else // Vertical orientation
            // Column 0 headers: label row + day rows
            table.cell(bt_table, 0, 0, bt_sigLabel, text_color=color.black, bgcolor=bt_lblColor, text_halign=text.align_center, text_size=bt_tblSize)
            for d = 0 to bt_numDays - 1
                int dayNum = bt_dStart + d
                table.cell(bt_table, 0, d + 1, "Day " + str.tostring(dayNum), text_color=color.black, bgcolor=bt_lblColor, text_halign=text.align_center, text_size=bt_tblSize)

            // Column headers (row 0)
            for r = 0 to array.size(bt_rowLabels) - 1
                table.cell(bt_table, r + 1, 0, array.get(bt_rowLabels, r), text_color=color.white, bgcolor=bt_hdrColor, text_halign=text.align_center, text_size=bt_tblSize)
            table.cell(bt_table, array.size(bt_rowLabels) + 1, 0, "Signals", text_color=color.white, bgcolor=bt_hdrColor, text_halign=text.align_center, text_size=bt_tblSize)

            // Data cells
            for d = 0 to bt_numDays - 1
                if d < array.size(bt_avgGain)
                    float ag  = array.get(bt_avgGain, d)
                    float al  = array.get(bt_avgLoss, d)
                    int   w   = array.get(bt_wins, d)
                    int   l   = array.get(bt_losses, d)
                    int   tot = w + l
                    float wp  = tot > 0 ? (w / tot) * 100 : 0
                    float rr  = array.get(bt_rr, d)
                    float tg  = array.get(bt_totalGain, d) + array.get(bt_totalLoss, d)

                    color gainCol = ag >= 0 ? color.new(color.green, 60) : color.new(color.red, 60)
                    color lossCol = color.new(color.red, 60)
                    color winCol  = wp >= 50 ? color.new(color.green, 60) : color.new(color.red, 60)
                    color rrCol   = rr >= 1 ? color.new(color.green, 60) : color.new(color.orange, 60)

                    table.cell(bt_table, 1, d + 1, str.tostring(ag, "#.##") + "%", text_color=color.white, bgcolor=gainCol, text_halign=text.align_center, text_size=bt_tblSize)
                    table.cell(bt_table, 2, d + 1, str.tostring(al, "#.##") + "%", text_color=color.white, bgcolor=lossCol, text_halign=text.align_center, text_size=bt_tblSize)
                    table.cell(bt_table, 3, d + 1, str.tostring(wp, "#.##") + "%", text_color=color.white, bgcolor=winCol, text_halign=text.align_center, text_size=bt_tblSize)
                    table.cell(bt_table, 4, d + 1, str.tostring(rr, "#.##"), text_color=color.white, bgcolor=rrCol, text_halign=text.align_center, text_size=bt_tblSize)
                    table.cell(bt_table, 5, d + 1, str.tostring(tg, "#.##") + "%", text_color=color.white, bgcolor=bt_valColor, text_halign=text.align_center, text_size=bt_tblSize)
                    string lodStr = not na(bt_avgBarsToLOD) ? str.tostring(bt_avgBarsToLOD, "#.1") : "N/A"
                    table.cell(bt_table, 6, d + 1, lodStr, text_color=color.white, bgcolor=bt_valColor, text_halign=text.align_center, text_size=bt_tblSize)
                    table.cell(bt_table, 7, d + 1, str.tostring(tot), text_color=color.white, bgcolor=bt_valColor, text_halign=text.align_center, text_size=bt_tblSize)

if bt_enabled
    f_populateBacktestTable()

// === DATA WINDOW OUTPUTS ===
plot(brk_showAutoCalc ? brkATR : na, "ATR Value ($)", display=display.data_window)
plot(brk_showAutoCalc ? actualDollarThresh : na, "Actual Trigger: Required Breakout ($)", display=display.data_window)
plot(brk_showAutoCalc ? calcAutoMult : na, "Calculator: Ref % equals (ATR×)", display=display.data_window)
plot(brk_showAutoCalc ? calcDollarThresh : na, "Calculator: Ref % equals ($)", display=display.data_window)

// ── NEW: Macro Zone in Data Window ──
plot(macro_composite, "Macro Composite Score", display=display.data_window)
plot(macro_action_code, "Macro Action Code (0-4)", display=display.data_window)
plot(idx_score, "Index Score", display=display.data_window)
plot(brd_score, "Breadth Score", display=display.data_window)
plot(mmfi_score, "MMFI Score", display=display.data_window)
plot(vix_score, "VIX Score", display=display.data_window)
