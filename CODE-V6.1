float macro_composite = screenerMode ? 75.0 : 
     (idx_score * macro_w_idx) + (brd_score * macro_w_brd) + (mmfi_score * macro_w_mmfi) + (vix_score * macro_w_vix)

// Clamp to 0-100
macro_composite := math.max(0, math.min(100, macro_composite))

// Zone Classification
string macro_action_text = "CASH / HEDGE | B/O FAIL"
int    macro_action_code = 0
color  macro_action_col  = macro_col_z1

if macro_composite >= macro_z5_thresh
