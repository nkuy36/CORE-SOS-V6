    macro_action_code := 4
    macro_action_col  := macro_col_z5
else if macro_composite >= macro_z4_thresh
    macro_action_text := "FULL SIZE | B/O WORK"
    macro_action_code := 3
    macro_action_col  := macro_col_z4
else if macro_composite >= macro_z3_thresh
    macro_action_text := "HALF SIZE | THEME B/O"
    macro_action_code := 2
    macro_action_col  := macro_col_z3
else if macro_composite >= macro_z2_thresh
    macro_action_text := "TRAPS ONLY | B/O FAIL"
    macro_action_code := 1
    macro_action_col  := macro_col_z2

