// 1. SPY TECHNICALS (Trend + Chop)
f_chopIndex_calc() =>
    _atrSum = math.sum(ta.atr(1), chopPeriod)
    _hiMax = ta.highest(high, chopPeriod)
    _loMin = ta.lowest(low, chopPeriod)
    _denom = _hiMax - _loMin
    _denom := _denom == 0 ? 1 : _denom
    100 * math.log10(_atrSum / _denom) / math.log10(chopPeriod)

[req_idxClose, req_idxSMA200, req_idxChopVal, req_idxEMA21, req_idxSMA50, req_idxSMA150] = request.security(mktIndex, fixedTF, [close, ta.sma(close, 200), f_chopIndex_calc(), ta.ema(close, 21), ta.sma(close, 50), ta.sma(close, 150)])

idxClose   = screenerMode ? close : req_idxClose
idxSMA200  = screenerMode ? float(na) : req_idxSMA200
idxChopVal = screenerMode ? 38.0 : req_idxChopVal
idxEMA21   = screenerMode ? float(na) : req_idxEMA21
idxSMA50   = screenerMode ? float(na) : req_idxSMA50
idxSMA150  = screenerMode ? float(na) : req_idxSMA150

// ── NEW: SPY INDEX SCORE (matches Macro Command Center logic) ──
float idx_score = 0.0
string spy_trend = "BEAR"
if not screenerMode
    if idxClose < idxSMA200
        idx_score := 0, spy_trend := "BEAR"
    else if idxClose < idxSMA50
        idx_score := 35, spy_trend := "DEEP PULLBACK"
    else if idxClose < idxEMA21
        idx_score := 60, spy_trend := "PULLBACK"
    else if idxEMA21 > idxSMA50 and idxSMA50 > idxSMA150 and idxSMA150 > idxSMA200
        idx_score := 100, spy_trend := "POWER TREND"
    else
        idx_score := 75, spy_trend := "UPTREND"
else
    idx_score := 75

// 2. SECTOR BREADTH ENGINE (LUK LOGIC)
core_syms = array.from("SMH", "IGV", "XLK", "XLC", "IBIT", "XLF", "XLE", "XLI", "ITA", "JETS", "GLD", "COPX", "URA", "XLV", "XBI", "TLT", "UUP", "XLU")

int sectors_leading = 0
int total_sectors = array.size(core_syms)

for i = 0 to total_sectors - 1
    string s = array.get(core_syms, i)
    [bc, b9, b21, b50] = request.security(s, "D", [close, ta.ema(close, 9), ta.ema(close, 21), ta.ema(close, 50)], ignore_invalid_symbol=true)
    if not screenerMode and bc > b9 and b9 > b21 and b21 > b50
        sectors_leading += 1

if screenerMode
    sectors_leading := total_sectors

float breadth_pct = screenerMode ? 100.0 : (sectors_leading / total_sectors) * 100
bool breadth_ok = screenerMode ? true : breadth_pct >= breadthThresh

// ── NEW: BREADTH SCORE (0-100 mapped from participation %) ──
float brd_score = math.min(100, breadth_pct * 1.5) // 66%+ participation → 100 score

// 3. MMFI
[req_mmfi_c, req_mmfi_c1, req_mmfi_sma50] = request.security("MMFI", "D", [close, close[1], ta.sma(close, 50)], ignore_invalid_symbol=true)

mmfi_c     = screenerMode ? float(na) : req_mmfi_c
mmfi_c1    = screenerMode ? float(na) : req_mmfi_c1
mmfi_sma50 = screenerMode ? float(na) : req_mmfi_sma50

// ── NEW: MMFI SCORE (matches Macro Command Center zones) ──
float mmfi_score = 50.0
if not screenerMode and not na(mmfi_c)
    if mmfi_c < 20
        mmfi_score := 85   // Capitulation = contrarian bullish
    else if mmfi_c < 40
        mmfi_score := 30   // Bearish
    else if mmfi_c > 75
        mmfi_score := 40   // Overheated
    else if mmfi_c > 60
        mmfi_score := 75   // Healthy
    // Adjust for trend
    bool mmfi_rising = mmfi_c > mmfi_c1
    if mmfi_rising and mmfi_c > req_mmfi_sma50
        mmfi_score += 10
    else if not mmfi_rising and mmfi_c < req_mmfi_sma50
        mmfi_score -= 10

// ── NEW: VIX MODULE (1 security call) ──
[req_vix_c, req_vix_sma10] = request.security("VIX", "D", [close, ta.sma(close, 10)], ignore_invalid_symbol=true)

float vix_c    = screenerMode ? 15.0 : req_vix_c
float vix_sma10 = screenerMode ? 15.0 : req_vix_sma10

// ── NEW: VIX SCORE (inverted: low VIX = high score) ──
float vix_score = 70.0
if not screenerMode and not na(vix_c)
    if vix_c > macro_vix_extr
        vix_score := 75    // Extreme = contrarian
    else if vix_c > macro_vix_fear
        vix_score := 60    // Fear
    else if vix_c > macro_vix_elev
        vix_score := 45    // Elevated
    // else stays 70 (complacent/normal)

